{
  "name": "@jayavibhavnk/pnyx",
  "version": "0.3.0",
  "description": "Shared assembly for agent memory — hand off context between coding agents mid-task (optional Agentfuse integration).",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./agentfuse": {
      "types": "./dist/agentfuse.d.ts",
      "import": "./dist/agentfuse.js",
      "default": "./dist/agentfuse.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node ./scripts/smoke-dist.mjs",
    "verify": "npm run build && npm test && npm run typecheck && npm run smoke",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "agentfuse": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "agentfuse": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "agentfuse": "file:../agentfuse",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "memory",
    "agentfuse",
    "handoff",
    "context"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jayavibhavnk/Pnyx.git"
  },
  "bugs": {
    "url": "https://github.com/jayavibhavnk/Pnyx/issues"
  },
  "homepage": "https://github.com/jayavibhavnk/Pnyx#readme"
}
