{
  "name": "pnyx",
  "version": "0.1.0",
  "description": "Shared assembly for agent memory \u2014 hand off context between coding agents mid-task (built on Agentfuse).",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node ./scripts/smoke-dist.mjs",
    "verify": "npm run build && npm test && npm run typecheck && npm run smoke",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "agentfuse": "file:../agentfuse"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "memory",
    "agentfuse",
    "handoff",
    "context"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/pnyx.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_ORG/pnyx/issues"
  },
  "homepage": "https://github.com/YOUR_ORG/pnyx#readme"
}
